# Backend API
PORT=4000

# MySQL connection
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=2QVt7enWhfBxzJb.root
DB_PASSWORD=TU_PASSWORD_REAL
DB_NAME=sublimart

DB_SSL=true
DB_SSL_CA_PATH=./certs/isrgrootx1.pem
DB_SSL_REJECT_UNAUTHORIZED=true

# Frontend
# En desarrollo web puedes dejarlo vacio para usar /api con el proxy de Vite.
# En produccion (frontend separado del backend) define la URL publica de tu API.
# Ejemplo: VITE_API_URL=https://tu-api.onrender.com/api
VITE_API_URL=

# Seguridad/CORS para produccion (separar por comas)
# Ejemplo: CORS_ORIGINS=https://app.tudominio.com,https://tudominio.com
CORS_ORIGINS=

# Restricciones de acceso para cajeros
# Si es true, los cajeros solo podran iniciar sesion desde la app desktop
CASHIER_DESKTOP_ONLY=true
# Si es false, ningun cajero puede iniciar sesion desde la web
CASHIER_ALLOW_WEB_LOGIN=false
# Dejalo vacio si solo quieres bloquear cajeros fuera de desktop
# Ejemplo: CASHIER_ALLOWED_IPS=186.33.120.10,190.86.22.5
CASHIER_ALLOWED_IPS=190.150.37.72
# Lista opcional de origins permitidos para cajeros (separados por comas)
# Usalo solo si habilitas CASHIER_ALLOW_WEB_LOGIN=true
# Ejemplo: CASHIER_ALLOWED_ORIGINS=https://sistematienda.com
CASHIER_ALLOWED_ORIGINS=https://sistematienda.com